{
  "transcriber": {
    "id": "whisperx_vad",
    "opts": {
      "model": "small",
      "device": "cpu",
      "compute_type": "int8"
    }
  },
  "post": [
    {
      "id": "clean_word_timings",
      "opts": {
        "tiny_gap_ms": 300.0
      }
    },
    {
      "id": "filter_fillers",
      "opts": {}
    },
    {
      "id": "filter_low_confidence",
      "opts": {
        "min_conf": 0.4
      }
    },
    {
      "id": "adjust_short_words",
      "opts": {
        "max_len": 0.30,
        "min_extend": 0.10
      }
    }
  ]
}